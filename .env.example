# Server
PORT=3000
SERVER_URL=https://auth.marketing.qih-tech.com
NODE_ENV=production

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Security
# JWT_SECRET signs both the session cookie and MCP access tokens issued by
# /auth/mcp-token. The analytics MCP server must be configured with the SAME
# value to verify those tokens (HS256 shared-secret bridge).
JWT_SECRET=generate-with-openssl-rand-hex-32
ALLOWED_DOMAIN=quantum.media

# Cookie
COOKIE_DOMAIN=.marketing.qih-tech.com
COOKIE_NAME=qm_session

# Admin
SUPER_ADMIN=alessandro.moretti@quantum.media

# MCP
# Full URL to the analytics MCP server endpoint. Rendered into the
# claude_desktop_config.json snippet on the /auth/mcp-token bridge page.
MCP_SERVER_URL=https://analytics-mcp.marketing.qih-tech.com/mcp
